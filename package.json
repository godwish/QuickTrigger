{
  "name": "quick-trigger",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch --env-file=.env apps/server/src/index.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:server": "tsc -p apps/server/tsconfig.json",
    "start": "node dist/server/index.js",
    "start:hosted": "HOST=0.0.0.0 node dist/server/index.js",
    "typecheck": "tsc -p apps/server/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit",
    "db:generate": "./node_modules/node/bin/node ./node_modules/prisma/build/index.js generate",
    "db:migrate": "./node_modules/node/bin/node ./node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "./node_modules/node/bin/node ./node_modules/prisma/build/index.js migrate deploy",
    "db:push": "./node_modules/node/bin/node ./node_modules/prisma/build/index.js db push",
    "db:seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.8.0",
    "node": "^22.22.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.24",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.8"
  }
}
